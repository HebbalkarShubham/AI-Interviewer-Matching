# Zoho CRM MCP Server - copy to .env and fill in values
# Create app at https://api-console.zoho.com (Server-based Applications)
# Get tokens: run from this folder: py -m zoho_mcp.auth_cli  (or uvx --from zoho-crm-mcp zoho-mcp-auth)

ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REDIRECT_URI=http://localhost:8080/callback
ZOHO_API_DOMAIN=https://www.zohoapis.com
# For Zoho India use: ZOHO_ACCOUNTS_URL=https://accounts.zoho.in  (and ZOHO_API_DOMAIN=https://www.zohoapis.in)
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
ZOHO_SCOPE=ZohoCRM.modules.ALL,ZohoCRM.users.READ

# From zoho-mcp-auth (add after first OAuth run - use the two DIFFERENT values it prints)
# ACCESS_TOKEN = short-lived (e.g. 1 hr). REFRESH_TOKEN = long-lived; used to get new access tokens.
# If access token expires: leave ZOHO_REFRESH_TOKEN set and clear ZOHO_ACCESS_TOKEN (or re-run run-auth.py).
ZOHO_ACCESS_TOKEN=your_generated_access_token
ZOHO_REFRESH_TOKEN=your_generated_refresh_token
