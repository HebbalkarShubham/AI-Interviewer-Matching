# Microsoft 365 MCP Server - copy to .env and fill in values
# Get these from Azure Portal: App registrations -> Your app -> Overview / Certificates & secrets

MS365_MCP_CLIENT_ID=your-azure-ad-app-client-id
MS365_MCP_CLIENT_SECRET=your-azure-ad-app-client-secret
MS365_MCP_TENANT_ID=common

# Optional: enable work/school features (Teams, SharePoint, shared mailbox, users)
# MS365_MCP_ORG_MODE=true

# Optional: cloud (global or china)
# MS365_MCP_CLOUD_TYPE=global
