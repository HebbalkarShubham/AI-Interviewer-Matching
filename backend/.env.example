# Copy to .env and fill in values.
# On EC2: .env is not deployed (excluded for security). Either create backend/.env on the server
# manually, or set GitHub secret EC2_ENV_FILE = base64 of this file (e.g. base64 -w0 backend/.env).

# Database (required)
DATABASE_URL=mysql+pymysql://user:password@host:3306/database_name

# OpenAI (required for skill extraction and match explanation)
OPENAI_API_KEY=sk-your-key

# SMTP (optional - for sending email when interviewer is selected)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@example.com

# AWS S3 (resume uploads - optional; if not set, resume is not stored on S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name
